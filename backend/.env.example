# Copy to .env and fill in values.

# Comma-separated GitHub user.login values allowed to use this deployment (case-insensitive).
# Leave unset or empty for open access (typical local dev). Set in production to restrict access.
# GECKODE_ALLOWED_LOGINS=alice,bob

# Database: default SQLite, or Postgres e.g. postgresql+psycopg://USER:PASS@HOST:5432/postgres?sslmode=require (Supabase).
# DATABASE_URL=sqlite:///./geckode.db

# Bearer token cache TTL (seconds) for GitHub GET /user avoidance — see bearer_cache.py.
# BEARER_CACHE_TTL_SEC=90

GEMINI_API_KEY=
# Primary model (also default when FAST/STRONG unset).
GEMINI_MODEL=gemini-3-flash-preview
# Optional council routing — fallback is GEMINI_MODEL.
# GEMINI_MODEL_FAST=
# GEMINI_MODEL_STRONG=
# GEMINI_MODEL_SYNTHESIS=
GITHUB_TOKEN=
# Optional: comma-separated GitHub user.login values to import for review snapshots (default: GITHUB_TOKEN user only).
# Use when inline comments are posted by a different bot than the API token, e.g. my-app[bot],geckode
# GECKODE_SYNC_LOGINS=
WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
PUBLIC_BASE_URL=http://localhost:8080
SESSION_SECRET=change-me
FRONTEND_ORIGIN=http://localhost:3000

# Fernet key for encrypting OAuth tokens and webhook secrets at rest (same key at runtime).
# Generate once (44-char url-safe base64 string, one line, no spaces):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# In AWS EB / other hosts: paste the raw key only — no surrounding "quotes". If the app says
# "invalid" or "Incorrect padding", regenerate and paste again (truncation breaks base64).
ENCRYPTION_KEY=
