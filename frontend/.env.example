# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-long-random-string

# GitHub OAuth App (re-use the same one as the FastAPI backend, OR create a second
# OAuth App whose Authorization callback URL is {NEXTAUTH_URL}/api/auth/callback/github).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Geckode FastAPI base URL (no trailing slash). Use same value for both in production.
GECKODE_API_URL=http://localhost:8080
# Same URL for browser-side fetches (public hostname only — never put secrets here).
NEXT_PUBLIC_GECKODE_API_URL=http://localhost:8080
